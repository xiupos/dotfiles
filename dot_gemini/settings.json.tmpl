{
  "security": {
    "auth": {
      "selectedType": "gemini-api-key"
    }
  },
  "mcpServers": {
    "inspirehep": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/MohamedElashri/inspirehep-mcp",
        "inspirehep-mcp"
      ]
    },
    "arxiv-latex": {
      "command": "uvx",
      "args": [
        "arxiv-latex-mcp"
      ]
    },
    "zotero": {
      "command": "/home/xiupos/.local/bin/zotero-mcp",
      "env": {
        "ZOTERO_LOCAL": "true",
        "ZOTERO_EMBEDDING_MODEL": "default"
      }
    },
    "obsidian-notes": {
      "command": "npx",
      "args": [
        "@bitbonsai/mcpvault",
        "/home/xiupos/Notes"
      ]
    },
    "nixos": {
      "command": "uvx",
      "args": ["mcp-nixos"]
    },
    "arch-linux": {
      "command": "uvx",
      "args": ["arch-ops-server"]
    },
    "github": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e", "GITHUB_PERSONAL_ACCESS_TOKEN",
        "-e", "GITHUB_READ_ONLY=1",
        "-e", "GITHUB_LOCKDOWN_MODE=1",
        "ghcr.io/github/github-mcp-server"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{{ .mcp.github_token }}"
      }
    },
    "grafana": {
      "command": "uvx",
      "args": ["mcp-grafana"],
      "env": {
        "GRAFANA_URL": "https://monitor.tail7b2934.ts.net/"
      }
    }
  }
}
