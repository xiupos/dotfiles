% macro
\newcommand{\slashed}[1]{{\displaystyle{\not}{#1}}}
\AtBeginDocument{
  \NewCommandCopy{\origtilde}{\~}
  \NewCommandCopy{\orighat}{\^}
  \NewCommandCopy{\origbar}{\=}
  \NewCommandCopy{\origdot}{\.}
  \NewCommandCopy{\origddot}{\"}

  \DeclareRobustCommand{\~}[1]{\ifmmode\tilde{#1}\else\origtilde{#1}\fi}
  \DeclareRobustCommand{\^}[1]{\ifmmode\hat{#1}\else\orighat{#1}\fi}
  \DeclareRobustCommand{\=}[1]{\ifmmode\bar{#1}\else\origbar{#1}\fi}
  \DeclareRobustCommand{\.}[1]{\ifmmode\dot{#1}\else\origdot{#1}\fi}
  \DeclareRobustCommand{\"}[1]{\ifmmode\ddot{#1}\else\origddot{#1}\fi}
}

% unicode replacement
